# Copy to .env.local and fill in real values (never commit .env.local).

NEXT_PUBLIC_SUPABASE_URL=https://hvogahprmyrneupsqttw.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key

# football-data.org API token (https://www.football-data.org/client/register)
FOOTBALL_DATA_API_TOKEN=your_football_data_api_token

# Optional: server-only key for admin sync (Supabase Dashboard → Settings → API → service_role)
# If omitted, sync uses the admin_bulk_upsert_teams database function instead.
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
